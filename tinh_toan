#include <iostream>
#include <string>
using namespace std;

class Student {
private:
    string name;
    int age;
    string gender;
    double gpa;

public:
    Student(string name, int age, string gender, double gpa) {
        this->name = name;
        this->age = age;
        this->gender = gender;
        this->gpa = gpa;
    }

    void display() {
        cout << "Name: " << name << endl;
        cout << "Age: " << age << endl;
        cout << "Gender: " << gender << endl;
        cout << "GPA: " << gpa << endl;
    }
};

#include <iostream>
using namespace std;

class ArrayCalculator {
public:
static int sumOfArray(int arr[], int n) {
    int sum = 0;
    for (int i = 0; i < n; i++){
        sum += arr[i];
    }
    return sum;
} 

static double sumOfArray(double arr[], int n) {
    double sum = 0;
    for (int i = 0; i < n; i++){
        sum += arr[i];
    }
    return sum;
}
};
